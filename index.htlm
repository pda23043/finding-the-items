<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8">
  <title>Finding The Items</title>
  <style>
    body {
      margin: 0;
      background: #111;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      font-family: Arial, sans-serif;
    }

    canvas {
      border: 4px solid #2b1b10;
      background: #5f4632;
    }
  </style>
</head>
<body>
  <canvas id="game" width="1200" height="800"></canvas>

  <script>
    const canvas = document.getElementById("game");
    const ctx = canvas.getContext("2d");

    function rect(x, y, w, h, color) {
      ctx.fillStyle = color;
      ctx.fillRect(x, y, w, h);
    }

    function circle(x, y, r, color) {
      ctx.fillStyle = color;
      ctx.beginPath();
      ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fill();
    }

    function drawRoom() {
      rect(0, 0, 1200, 800, "#5f4632");
      rect(0, 500, 1200, 300, "#462d1e");

      rect(450, 70, 300, 180, "#3c2814");
      rect(465, 85, 270, 150, "#5078aa");
      rect(595, 85, 10, 150, "#3c2814");
      rect(465, 155, 270, 10, "#3c2814");

      rect(80, 180, 180, 320, "#5a3c1e");
      rect(80, 250, 180, 5, "#321e0f");
      rect(80, 320, 180, 5, "#321e0f");
      rect(80, 390, 180, 5, "#321e0f");
      rect(80, 460, 180, 5, "#321e0f");

      rect(900, 180, 180, 130, "#321e0f");
      rect(915, 195, 150, 100, "#8c8c78");

      rect(450, 400, 300, 120, "#644128");
      rect(470, 520, 20, 80, "#644128");
      rect(710, 520, 20, 80, "#644128");

      rect(120, 550, 260, 120, "#3c5032");
      rect(100, 520, 40, 120, "#3c5032");
      rect(360, 520, 40, 120, "#3c5032");

      rect(950, 350, 140, 250, "#503219");
      circle(1060, 480, 8, "#dcb428");
    }

    drawRoom();
  </script>
</body>
</html>
